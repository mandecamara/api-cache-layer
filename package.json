{
  "name": "api-cache-layer",
  "version": "1.0.0",
  "description": "Intelligent caching layer for API calls with memory, Redis, dynamic TTL, and auto-invalidation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --coverage",
    "lint": "eslint src --ext .ts"
  },
  "keywords": ["cache", "redis", "api", "ttl", "axios", "fetch", "performance"],
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.0"
  },
  "optionalDependencies": {
    "ioredis": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["src/**/*.ts"]
  }
